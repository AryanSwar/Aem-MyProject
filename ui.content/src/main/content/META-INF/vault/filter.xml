<?xml version="1.0" encoding="UTF-8"?>
<workspaceFilter version="1.0">
    <filter root="/conf/myproject" mode="merge"/>
    <filter root="/content/myproject" mode="merge"/>
    <filter root="/content/dam/myproject" mode="merge">
        <exclude pattern="/content/dam/myproject(/.*)?"/>
        <include pattern="/content/dam/myproject/jcr:content(/.*)?"/>
    </filter>
    <filter root="/content/dam/myproject/asset.jpg" mode="merge"/>
    <filter root="/content/experience-fragments/myproject" mode="merge"/>

    <filter root="/conf/global/settings/dam/adminui-extension/metadataschema/employee-schema" mode="merge"/> <!-- for metadata schema creation-->

    <filter root="/conf/global/settings/dam/adminui-extension/metadataschema/employee-form" mode="merge"/> <!-- for metadata schema creation-->


    <filter root="/conf/global/settings/dam/search/facets/assets" mode="merge"/> <!--for creating search filter-->

    <filter root="/conf/global/settings/workflow/models/dynamic-content-approval"/> <!--for workflow model-->

    <filter root="/conf/global/settings/workflow/launcher/config/myproject-product-launcher"/> <!--for launcher dynamic content approval-->
</workspaceFilter>
